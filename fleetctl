def run_tui() -> None:
    import curses
    if not DB_PATH.exists():
        init_db()
    curses.wrapper(_tui_main)


def _tui_main(stdscr) -> None:
    import curses
    curses.curs_set(0)
    conn = get_conn()

    main_menu = [
        ("New unit", _tui_new_unit),
        ("List units", _tui_list_units),
        ("Show unit details", _tui_show_unit),
        ("Update status", _tui_status),
        ("Mark sold", _tui_sell),
        ("Warranty claim", _tui_warranty),
        ("Set acquisition info", _tui_acquisition),
        ("Repurpose unit", _tui_repurpose),
        ("Import hardware config", _tui_hardware_import),
        ("Save completed checklist", _tui_checklist_save),
        ("Add part replacement", _tui_part_add),
        ("List part replacements", _tui_part_list),
        ("Print handoff card", _tui_handoff_card),
        ("Purge temp secrets", _tui_purge_secrets),
        ("Manage builds", _tui_builds_menu),
        ("Quit", None),
    ]

    while True:
        choice = _select_list(stdscr, "fleetctl", main_menu, formatter=lambda x: x[0])
        if choice is None or choice[1] is None:
            break
        try:
            choice[1](stdscr, conn)
        except FleetError as e:
            _message_screen(stdscr, f"Error: {e}")
        except Exception as e:  # keep the menu alive even on an unexpected bug
            _message_screen(stdscr, f"Unexpected error: {e}")


# --- generic curses widgets ---

def _select_list(stdscr, title, items, formatter=str, extra_help=""):
    import curses
    if not items:
        _message_screen(stdscr, f"{title}\n\n(nothing to show)")
        return None
    idx = top = 0
    while True:
        stdscr.erase()
        h, w = stdscr.getmaxyx()
        stdscr.addnstr(0, 0, title, max(w - 1, 0), curses.A_BOLD)
        help_line = "up/down move   enter select   q back" + (f"   {extra_help}" if extra_help else "")
        stdscr.addnstr(1, 0, help_line, max(w - 1, 0), curses.A_DIM)
        visible_rows = max(h - 3, 1)
        if idx < top:
            top = idx
        if idx >= top + visible_rows:
            top = idx - visible_rows + 1
        for row, i in enumerate(range(top, min(len(items), top + visible_rows))):
            text = formatter(items[i])
            attr = curses.A_REVERSE if i == idx else curses.A_NORMAL
            stdscr.addnstr(3 + row, 0, text, max(w - 1, 0), attr)
        stdscr.refresh()
        key = stdscr.getch()
        if key in (curses.KEY_UP, ord('k')):
            idx = (idx - 1) % len(items)
        elif key in (curses.KEY_DOWN, ord('j')):
            idx = (idx + 1) % len(items)
        elif key in (10, 13, curses.KEY_ENTER, ord(' ')):
            return items[idx]
        elif key in (27, ord('q'), curses.KEY_LEFT):
            return None


def _text_viewer(stdscr, title, lines):
    import curses
    offset = 0
    while True:
        stdscr.erase()
        h, w = stdscr.getmaxyx()
        stdscr.addnstr(0, 0, title, max(w - 1, 0), curses.A_BOLD)
        stdscr.addnstr(1, 0, "up/down scroll   q back", max(w - 1, 0), curses.A_DIM)
        visible_rows = max(h - 3, 1)
        offset = max(0, min(offset, max(len(lines) - visible_rows, 0)))
        for row, line in enumerate(lines[offset:offset + visible_rows]):
            stdscr.addnstr(3 + row, 0, line, max(w - 1, 0))
        stdscr.refresh()
        key = stdscr.getch()
        if key in (curses.KEY_UP, ord('k')):
            offset = max(0, offset - 1)
        elif key in (curses.KEY_DOWN, ord('j')):
            offset += 1
        elif key in (curses.KEY_NPAGE,):
            offset += visible_rows
        elif key in (curses.KEY_PPAGE,):
            offset = max(0, offset - visible_rows)
        elif key in (27, ord('q'), 10, 13):
            return


def _message_screen(stdscr, text):
    stdscr.erase()
    h, w = stdscr.getmaxyx()
    lines = text.splitlines() or [""]
    for i, line in enumerate(lines[: max(h - 2, 1)]):
        stdscr.addnstr(i, 0, line, max(w - 1, 0))
    stdscr.addnstr(max(h - 1, 0), 0, "-- press any key to continue --", max(w - 1, 0))
    stdscr.refresh()
    stdscr.getch()


def _text_prompt(stdscr, prompt, default=None):
    import curses
    curses.endwin()
    try:
        suffix = f" [{default}]" if default not in (None, "") else ""
        raw = input(f"{prompt}{suffix}: ").strip()
    finally:
        stdscr.touchwin()
        stdscr.refresh()
        curses.curs_set(0)
    return raw if raw else (default or "")


def _confirm(stdscr, question) -> bool:
    choice = _select_list(stdscr, question, ["Yes", "No"])
    return choice == "Yes"


TIER_CHOICES = ["(none)", "1", "2", "3"]


def _pick_tier(stdscr, title="Tier"):
    choice = _select_list(stdscr, title, TIER_CHOICES)
    if choice in (None, "(none)"):
        return None
    return int(choice)


def _pick_build(stdscr, conn, line=None, title="Build (optional)"):
    builds = op_list_builds(conn)
    if line:
        builds = [b for b in builds if b["product_line"] == line]
    options = ["(none)"] + list(builds)
    choice = _select_list(stdscr, title, options,
                           formatter=lambda b: "(none)" if b == "(none)" else b["build_id"])
    if choice in (None, "(none)"):
        return None
    return choice["build_id"]


def _pick_unit(stdscr, conn, title="Select unit"):
    rows = op_list_units(conn)
    if not rows:
        _message_screen(stdscr, "No units yet. Create one with 'New unit' first.")
        return None

    def fmt(r):
        tier = f"t{r['tier']}" if r["tier"] else ""
        return (f"{r['serial']:<20} {r['product_line']}{tier:<3} "
                f"{(r['oem_make'] or '-'):<10} {(r['oem_model'] or '-'):<16} {r['status']}")

    row = _select_list(stdscr, title, rows, formatter=fmt)
    return row["serial"] if row else None


# --- menu actions ---

def _tui_new_unit(stdscr, conn):
    line_choice = _select_list(stdscr, "Product line", ["laptop", "pixel"])
    if line_choice is None:
        return
    tier = _pick_tier(stdscr, "Tier")
    make = _text_prompt(stdscr, "OEM make (e.g. Lenovo, blank to skip)")
    model = _text_prompt(stdscr, "OEM model (e.g. ThinkPad T480, blank to skip)")
    build = _pick_build(stdscr, conn, line=line_choice)
    mfg_date = _text_prompt(stdscr, "Manufacture date YYYY-MM-DD (blank = today)")
    words_str = _text_prompt(stdscr, "Words per passphrase", default="6")
    words = int(words_str) if words_str else 6

    result = op_create_unit(conn, line_choice, tier, make or None, model or None,
                             build, mfg_date or None, words)
    lines = [
        f"Created unit {result['serial']}",
        f"line/tier:  {result['line']} / tier {result['tier'] or '-'}",
        f"make/model: {result['make'] or '-'} {result['model'] or '-'}",
        f"build:      {result['build'] or '-'}",
        f"mfg date:   {result['mfg_date']}",
        "",
        "--- handoff card (temporary — buyer must change all three) ---",
        f"login passphrase: {result['login_passphrase']}",
        f"UEFI passphrase:  {result['uefi_passphrase']}",
        f"LUKS passphrase:  {result['luks_passphrase']}",
    ]
    _message_screen(stdscr, "\n".join(lines))


def _tui_list_units(stdscr, conn):
    status = _select_list(stdscr, "Filter by status", ["(all)"] + STATUS_FLOW)
    if status is None:
        return
    line = _select_list(stdscr, "Filter by line", ["(all)", "laptop", "pixel"])
    if line is None:
        return
    rows = op_list_units(conn, None if status == "(all)" else status,
                          None if line == "(all)" else line)
    if not rows:
        _message_screen(stdscr, "No units found.")
        return
    header = f"{'SERIAL':<20} {'LINE':<7} {'TIER':<5} {'MAKE':<10} {'MODEL':<14} {'STATUS':<11} {'MFG':<11} {'SOLD':<11}"
    lines = [header, "-" * len(header)]
    for r in rows:
        lines.append(
            f"{r['serial']:<20} {r['product_line']:<7} {str(r['tier'] or '-'):<5} "
            f"{(r['oem_make'] or '-'):<10} {(r['oem_model'] or '-'):<14} {r['status']:<11} "
            f"{r['date_of_manufacture']:<11} {(r['date_of_sale'] or '-'):<11}"
        )
    _text_viewer(stdscr, "Units", lines)


def _tui_show_unit(stdscr, conn):
    serial = _pick_unit(stdscr, conn)
    if not serial:
        return
    unit = op_get_unit(conn, serial)
    d = dict(unit)
    hw = d.pop("hardware_config_json", None)
    lines = json.dumps(d, indent=2).splitlines()
    if hw:
        lines += ["--- hardware_config ---"] + json.dumps(json.loads(hw), indent=2).splitlines()
    parts = op_list_part_replacements(conn, serial)
    if parts:
        lines += ["--- part replacements ---"]
        for r in parts:
            lines += json.dumps(dict(r), indent=2).splitlines()
    _text_viewer(stdscr, f"Unit {serial}", lines)


def _tui_status(stdscr, conn):
    serial = _pick_unit(stdscr, conn)
    if not serial:
        return
    new_status = _select_list(stdscr, "New status", STATUS_FLOW)
    if not new_status:
        return
    op_set_status(conn, serial, new_status)
    _message_screen(stdscr, f"{serial} -> {new_status}")


def _tui_sell(stdscr, conn):
    serial = _pick_unit(stdscr, conn)
    if not serial:
        return
    sale_date = _text_prompt(stdscr, "Sale date YYYY-MM-DD (blank = today)")
