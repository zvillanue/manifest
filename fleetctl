# CLI wiring
# --------------------------------------------------------------------------

def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(prog="fleetctl", description=__doc__)
    sub = p.add_subparsers(dest="command")

    sub.add_parser("init", help="Create the database").set_defaults(func=cmd_init)
    sub.add_parser("gen-key", help="Generate a new database encryption key").set_defaults(func=cmd_gen_key)
    sub.add_parser("menu", help="Interactive arrow-key menu (also runs if no subcommand given)").set_defaults(func=cmd_menu)

    b = sub.add_parser("build", help="Register/inspect post-install builds")
    bsub = b.add_subparsers(dest="build_command", required=True)

    br = bsub.add_parser("register", help="Register a build id -> post-install script")
    br.add_argument("--id", required=True, help="build id, e.g. laptop-tier1-mint-v3")
    br.add_argument("--line", required=True, choices=LINE_PREFIXES.keys())
    br.add_argument("--tier", type=int, default=None)
    br.add_argument("--script", required=True, help="path to the post-install script")
    br.add_argument("--desc", default=None)
    br.set_defaults(func=cmd_build_register)

    bl = bsub.add_parser("list", help="List registered builds")
    bl.set_defaults(func=cmd_build_list)

    bv = bsub.add_parser("verify", help="Check a build's script hasn't changed since registration")
    bv.add_argument("id")
    bv.set_defaults(func=cmd_build_verify)

    n = sub.add_parser("new", help="Create a new unit (generates serial + temp passphrases)")
    n.add_argument("--line", required=True, choices=LINE_PREFIXES.keys())
    n.add_argument("--tier", type=int, default=None)
    n.add_argument("--make", default=None, help="OEM make, e.g. Lenovo")
    n.add_argument("--model", default=None, help="OEM model, e.g. ThinkPad T480")
    n.add_argument("--build", default=None, help="build id (see `fleetctl build list`)")
    n.add_argument("--mfg-date", default=None, help="YYYY-MM-DD, defaults to today")
    n.add_argument("--words", type=int, default=6, help="words per passphrase (default 6)")
    n.add_argument("--acquisition-date", default=None, help="YYYY-MM-DD, when you acquired this unit")
    n.add_argument("--acquisition-source", default=None, help="where you got it, e.g. eBay, Craigslist")
    n.add_argument("--acquisition-cost", default=None, help="what you paid, e.g. 110")
    n.set_defaults(func=cmd_new)

    hi = sub.add_parser("hardware-import", help="Attach a hardware-inventory.sh JSON dump to a unit")
    hi.add_argument("serial")
    hi.add_argument("json_file")
    hi.set_defaults(func=cmd_hardware_import)

    cs = sub.add_parser("checklist-save", help="Copy a completed checklist into checklists/")
    cs.add_argument("serial")
    cs.add_argument("path")
    cs.set_defaults(func=cmd_checklist_save)

    st = sub.add_parser("status", help="Update a unit's pipeline status")
    st.add_argument("serial")
    st.add_argument("new_status", choices=STATUS_FLOW)
    st.set_defaults(func=cmd_status)

    sl = sub.add_parser("sell", help="Record date of sale (and price)")
    sl.add_argument("serial")
    sl.add_argument("--date", default=None, help="YYYY-MM-DD, defaults to today")
    sl.add_argument("--price", default=None)
    sl.add_argument("--buyer-name", default=None, help="Used to create/find the customer in Dolibarr, if configured")
    sl.add_argument("--buyer-email", default=None)
    sl.set_defaults(func=cmd_sell)

    w = sub.add_parser("warranty", help="Flag a unit as warrantied and log a note")
    w.add_argument("serial")
    w.add_argument("--note", required=True)
    w.set_defaults(func=cmd_warranty)

    ac = sub.add_parser("acquisition", help="Set/update where, when, and how much a unit was acquired for")
    ac.add_argument("serial")
    ac.add_argument("--date", default=None, help="YYYY-MM-DD, defaults to today")
    ac.add_argument("--source", default=None, help="e.g. eBay, Craigslist, Facebook Marketplace")
    ac.add_argument("--cost", default=None, help="what you paid, e.g. 110")
    ac.set_defaults(func=cmd_acquisition)

    pt = sub.add_parser("part", help="Record parts swapped during refurb (old part + new part per record)")
    ptsub = pt.add_subparsers(dest="part_command", required=True)

    pa = ptsub.add_parser("add", help="Record a part replacement")
    pa.add_argument("serial")
    pa.add_argument("--type", required=True,
                     help=f"e.g. {', '.join(PART_TYPE_SUGGESTIONS)}, or anything else")
    pa.add_argument("--replaced-at", default=None, help="YYYY-MM-DD, defaults to today")
    pa.add_argument("--old-make", default=None)
    pa.add_argument("--old-model", default=None)
    pa.add_argument("--old-model-number", default=None)
    pa.add_argument("--old-serial", default=None)
    pa.add_argument("--old-mfg-date", default=None, help="YYYY-MM-DD if known")
    pa.add_argument("--new-make", default=None)
    pa.add_argument("--new-model", default=None)
    pa.add_argument("--new-model-number", default=None)
    pa.add_argument("--new-serial", default=None)
    pa.add_argument("--new-mfg-date", default=None, help="YYYY-MM-DD if known")
    pa.add_argument("--notes", default=None)
    pa.set_defaults(func=cmd_part_add)

    pl = ptsub.add_parser("list", help="List part replacements for a unit")
    pl.add_argument("serial")
    pl.set_defaults(func=cmd_part_list)

    rp = sub.add_parser("repurpose", help="Retire a unit and spin up a new linked unit")
    rp.add_argument("serial")
    rp.add_argument("--new-line", choices=LINE_PREFIXES.keys(), default=None)
    rp.add_argument("--new-tier", type=int, default=None)
    rp.add_argument("--build", default=None)
    rp.add_argument("--words", type=int, default=6)
    rp.set_defaults(func=cmd_repurpose)

    ps = sub.add_parser("purge-secrets", help="Wipe stored temp passphrases once buyer has changed them")
    ps.add_argument("serial")
    ps.set_defaults(func=cmd_purge_secrets)

    sh = sub.add_parser("show", help="Print a unit's full record")
    sh.add_argument("serial")
    sh.set_defaults(func=cmd_show)

    ls = sub.add_parser("list", help="List units")
    ls.add_argument("--status", choices=STATUS_FLOW, default=None)
    ls.add_argument("--line", choices=LINE_PREFIXES.keys(), default=None)
    ls.set_defaults(func=cmd_list)

    hc = sub.add_parser("handoff-card", help="Print the printable handoff card for a unit")
    hc.add_argument("serial")
    hc.set_defaults(func=cmd_handoff_card)

    vs = sub.add_parser("verify-serial", help="Check a serial's check digit (catches typos)")
    vs.add_argument("serial")
    vs.set_defaults(func=cmd_verify_serial)

    sc = sub.add_parser("script", help="Generate a post-install script")
    scsub = sc.add_subparsers(dest="script_command", required=True)

    scsub.add_parser("oses", help="List OS targets the generator supports").set_defaults(func=cmd_script_oses)
    scsub.add_parser("apps", help="List the app catalog").set_defaults(func=cmd_script_apps)

    sg = scsub.add_parser("generate", help="Generate a post-install script")
    sg.add_argument("--os", required=True, choices=OS_TARGETS.keys())
    sg.add_argument("--apps", default="", help="comma-separated app ids, see `fleetctl script apps`")
    sg.add_argument("--tpm-unlock", action="store_true",
                     help="enroll TPM2 auto-unlock instead of a LUKS passphrase-change wizard")
    sg.add_argument("--uefi-reminder", action="store_true",
                     help="include a manual UEFI/BIOS password reminder (can't be automated cross-vendor)")
    sg.add_argument("--no-force-password-change", action="store_true",
                     help="don't force the Unix account password to be changed at next login")
    sg.add_argument("--no-auto-updates", action="store_true")
    sg.add_argument("--no-firewall", action="store_true")
    sg.add_argument("--no-zram-tlp", action="store_true")
    sg.add_argument("--no-printing-codecs", action="store_true")
    sg.add_argument("--no-grub-btrfs", action="store_true")
    sg.add_argument("--no-snapper", action="store_true")
    sg.add_argument("--no-oem-wallpaper", action="store_true",
                     help="don't set the Obsidian Devices wallpaper as the default background")
    sg.add_argument("--no-oem-bookmarks", action="store_true",
                     help="don't add the 'Stay Safe Online' default Firefox bookmarks")
    sg.add_argument("--no-oem-guide", action="store_true",
                     help="don't copy the beginner Linux guide folder to the Desktop")
    sg.add_argument("-o", "--output", default=None, help="write to this path instead of stdout")
    sg.add_argument("--register-build", default=None, metavar="BUILD_ID",
                     help="save under postinstall/generated/<id>.sh and register it as a build")
    sg.add_argument("--line", choices=LINE_PREFIXES.keys(), default="laptop",
                     help="product line, only used with --register-build (default: laptop)")
    sg.add_argument("--tier", type=int, default=None, help="only used with --register-build")
    sg.add_argument("--desc", default=None, help="only used with --register-build")
    sg.set_defaults(func=cmd_script_generate)

    return p


def main() -> None:
    parser = build_parser()
    args = parser.parse_args()
    if args.command is None:
        run_tui()
        return
    try:
        args.func(args)
    except FleetError as e:
        sys.exit(str(e))


if __name__ == "__main__":
    main()
