def _tui_part_add(stdscr, conn):
    serial = _pick_unit(stdscr, conn)
    if not serial:
        return
    part_type = _select_list(stdscr, "Part type", PART_TYPE_SUGGESTIONS + ["(other — type it in)"])
    if part_type is None:
        return
    if part_type == "(other — type it in)":
        part_type = ""
        while not part_type:
            part_type = _text_prompt(stdscr, "Part type")
    replaced_at = _text_prompt(stdscr, "Date replaced YYYY-MM-DD (blank = today)")

    _message_screen(stdscr, "Now the part that was REMOVED (blank any field you don't know).")
    old_make = _text_prompt(stdscr, "Old part make")
    old_model = _text_prompt(stdscr, "Old part model")
    old_model_number = _text_prompt(stdscr, "Old part model number")
    old_serial = _text_prompt(stdscr, "Old part serial number")
    old_mfg_date = _text_prompt(stdscr, "Old part date of manufacture YYYY-MM-DD")

    _message_screen(stdscr, "Now the part that was INSTALLED.")
    new_make = _text_prompt(stdscr, "New part make")
    new_model = _text_prompt(stdscr, "New part model")
    new_model_number = _text_prompt(stdscr, "New part model number")
    new_serial = _text_prompt(stdscr, "New part serial number")
    new_mfg_date = _text_prompt(stdscr, "New part date of manufacture YYYY-MM-DD")
    notes = _text_prompt(stdscr, "Notes (optional)")

    part_id = op_add_part_replacement(
        conn, serial, part_type, replaced_at or None,
        old_make=old_make or None, old_model=old_model or None,
        old_model_number=old_model_number or None, old_serial_number=old_serial or None,
        old_date_of_mfg=old_mfg_date or None,
        new_make=new_make or None, new_model=new_model or None,
        new_model_number=new_model_number or None, new_serial_number=new_serial or None,
        new_date_of_mfg=new_mfg_date or None,
        notes=notes or None,
    )
    _message_screen(stdscr, f"Recorded part replacement #{part_id} ({part_type}) for {serial}")


def _tui_part_list(stdscr, conn):
    serial = _pick_unit(stdscr, conn)
    if not serial:
        return
    rows = op_list_part_replacements(conn, serial)
    if not rows:
        _message_screen(stdscr, f"No part replacements recorded for {serial}.")
        return
    lines = []
    for r in rows:
        lines.append(f"#{r['id']}  {r['part_type']}  replaced {r['replaced_at']}")
        old = " / ".join(x for x in (r["old_make"], r["old_model"], r["old_model_number"]) if x)
        new = " / ".join(x for x in (r["new_make"], r["new_model"], r["new_model_number"]) if x)
        lines.append(f"  old: {old or '-'}"
                      + (f"  (S/N {r['old_serial_number']})" if r["old_serial_number"] else "")
                      + (f"  (mfg {r['old_date_of_mfg']})" if r["old_date_of_mfg"] else ""))
        lines.append(f"  new: {new or '-'}"
                      + (f"  (S/N {r['new_serial_number']})" if r["new_serial_number"] else "")
                      + (f"  (mfg {r['new_date_of_mfg']})" if r["new_date_of_mfg"] else ""))
        if r["notes"]:
            lines.append(f"  notes: {r['notes']}")
        lines.append("")
    _text_viewer(stdscr, f"Part replacements: {serial}", lines)


def _tui_repurpose(stdscr, conn):
    serial = _pick_unit(stdscr, conn, title="Select unit to repurpose")
    if not serial:
        return
    if not _confirm(stdscr, f"Repurpose {serial}? This retires it and creates a new linked unit."):
        return
    new_line = _select_list(stdscr, "New product line", ["laptop", "pixel"])
    if new_line is None:
        return
    new_tier = _pick_tier(stdscr, "New tier")
    build = _pick_build(stdscr, conn, line=new_line)
    words_str = _text_prompt(stdscr, "Words per passphrase", default="6")
    words = int(words_str) if words_str else 6
    result = op_repurpose(conn, serial, new_line, new_tier, build, words)
    lines = [
        f"{serial} -> Repurposed.",
        f"New unit {result['serial']} created (linked via repurposed_from).",
        "",
        "--- handoff card (temporary — buyer must change all three) ---",
        f"login passphrase: {result['login_passphrase']}",
        f"UEFI passphrase:  {result['uefi_passphrase']}",
        f"LUKS passphrase:  {result['luks_passphrase']}",
    ]
    _message_screen(stdscr, "\n".join(lines))


