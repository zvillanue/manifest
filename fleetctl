def _opts_from_args(args: argparse.Namespace) -> GenOptions:
    apps = [a.strip() for a in (args.apps or "").split(",") if a.strip()]
    unknown = [a for a in apps if a not in APPS]
    if unknown:
        raise FleetError(f"Unknown app id(s): {', '.join(unknown)}. See `fleetctl script apps`.")
    return GenOptions(
        os_id=args.os,
        apps=apps,
        luks_password_enabled=not args.tpm_unlock,
        uefi_password_reminder=args.uefi_reminder,
        force_user_password_change=not args.no_force_password_change,
        auto_updates=not args.no_auto_updates,
        firewall=not args.no_firewall,
        zram_tlp=not args.no_zram_tlp,
        printing_codecs=not args.no_printing_codecs,
        grub_btrfs=not args.no_grub_btrfs,
        snapper=not args.no_snapper,
        oem_wallpaper=not args.no_oem_wallpaper,
        oem_bookmarks=not args.no_oem_bookmarks,
        oem_guide_folder=not args.no_oem_guide,
    )


def cmd_script_generate(args: argparse.Namespace) -> None:
    if args.os not in OS_TARGETS:
        raise FleetError(f"Unknown OS '{args.os}'. See `fleetctl script oses`.")
    opts = _opts_from_args(args)
    script = generate_script(opts)

    if args.register_build:
        conn = require_db()
        GENERATED_DIR.mkdir(parents=True, exist_ok=True)
        dest = GENERATED_DIR / f"{args.register_build}.sh"
        dest.write_text(script)
        dest.chmod(0o755)
        rel_path, sha256 = op_register_build(
            conn, args.register_build, args.line, args.tier, str(dest), args.desc
        )
        print(f"Wrote {dest.relative_to(GENERATED_DIR.parent.parent)}")
        print(f"Registered build '{args.register_build}' -> {rel_path} (sha256 {sha256[:12]}...)")
    elif args.output:
        Path(args.output).write_text(script)
        Path(args.output).chmod(0o755)
        print(f"Wrote {args.output}")
    else:
        print(script)


