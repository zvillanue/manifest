def cmd_init(_args: argparse.Namespace) -> None:
    init_db()
    print(f"Initialized database at {DB_PATH}")


def cmd_gen_key(_args: argparse.Namespace) -> None:
    key = generate_db_key()
    print(key)
    print(file=sys.stderr)
    print("^ that's your new database encryption key (256-bit, hex-encoded).", file=sys.stderr)
    print("Save it in a password manager NOW — this is the only time it's printed, and", file=sys.stderr)
    print("fleetctl does not store it anywhere. There is no recovery if it's lost.", file=sys.stderr)
    print(file=sys.stderr)
    print("Then export it before running fleetctl:", file=sys.stderr)
    print(f"  export FLEETCTL_DB_KEY={key}", file=sys.stderr)
    print("(put that in your shell profile, or wherever you keep secrets — NOT in this", file=sys.stderr)
    print("Nextcloud-synced folder).", file=sys.stderr)


def cmd_build_register(args: argparse.Namespace) -> None:
    conn = require_db()
    rel_path, sha256 = op_register_build(conn, args.id, args.line, args.tier, args.script, args.desc)
    print(f"Registered build '{args.id}' -> {rel_path} (sha256 {sha256[:12]}...)")


def cmd_build_list(_args: argparse.Namespace) -> None:
    conn = require_db()
    rows = op_list_builds(conn)
    if not rows:
        print("No builds registered yet.")
        return
    for r in rows:
        tier = f" tier {r['tier']}" if r["tier"] else ""
        print(f"{r['build_id']}  [{r['product_line']}{tier}]")
        print(f"    script: {r['postinstall_script_path']}  (sha256 {r['script_sha256'][:12]}...)")
        if r["description"]:
            print(f"    {r['description']}")


def cmd_build_verify(args: argparse.Namespace) -> None:
    conn = require_db()
    ok, registered, current = op_verify_build(conn, args.id)
    if ok:
        print(f"OK: {args.id} script unchanged since registration.")
    else:
        print(f"MISMATCH: {args.id} script has changed since registration!")
        print(f"  registered sha256: {registered}")
        print(f"  current sha256:    {current}")
        sys.exit(1)


