def _tui_builds_menu(stdscr, conn):
    submenu = [
        ("List builds", _tui_build_list),
        ("Register a build", _tui_build_register),
        ("Verify a build's script hasn't changed", _tui_build_verify),
        ("Back", None),
    ]
    while True:
        choice = _select_list(stdscr, "Manage builds", submenu, formatter=lambda x: x[0])
        if choice is None or choice[1] is None:
            return
        choice[1](stdscr, conn)


def _tui_build_list(stdscr, conn):
    rows = op_list_builds(conn)
    if not rows:
        _message_screen(stdscr, "No builds registered yet.")
        return
    lines = []
    for r in rows:
        tier = f" tier {r['tier']}" if r["tier"] else ""
        lines.append(f"{r['build_id']}  [{r['product_line']}{tier}]")
        lines.append(f"    script: {r['postinstall_script_path']}  (sha256 {r['script_sha256'][:12]}...)")
        if r["description"]:
            lines.append(f"    {r['description']}")
    _text_viewer(stdscr, "Builds", lines)


def _tui_build_register(stdscr, conn):
    line = _select_list(stdscr, "Product line", ["laptop", "pixel"])
    if line is None:
        return
    tier = _pick_tier(stdscr, "Tier")
    build_id = ""
    while not build_id:
        build_id = _text_prompt(stdscr, "Build id (e.g. laptop-tier1-mint-v1)")
    script = ""
    while not script:
        script = _text_prompt(stdscr, "Path to post-install script/doc")
    desc = _text_prompt(stdscr, "Description (optional)")
    rel_path, sha256 = op_register_build(conn, build_id, line, tier, script, desc or None)
    _message_screen(stdscr, f"Registered build '{build_id}' -> {rel_path}\nsha256 {sha256}")


def _tui_build_verify(stdscr, conn):
    builds = op_list_builds(conn)
    if not builds:
        _message_screen(stdscr, "No builds registered yet.")
        return
    build = _select_list(stdscr, "Verify which build?", builds, formatter=lambda b: b["build_id"])
    if not build:
        return
    ok, registered, current = op_verify_build(conn, build["build_id"])
    if ok:
        _message_screen(stdscr, f"OK: {build['build_id']} script unchanged since registration.")
    else:
        _message_screen(
            stdscr,
            f"MISMATCH: {build['build_id']} script has changed since registration!\n"
            f"registered sha256: {registered}\ncurrent sha256:    {current}",
        )


