# Copy to .env (gitignored) and fill in real values. docker compose reads
# .env automatically from this directory — no need to export these by hand.

# Required. Generate with `fleetctl gen-key`. Never commit the real value.
FLEETCTL_DB_KEY=

# Recommended. Without these, the web UI runs with no authentication.
FLEETCTL_WEB_USER=
FLEETCTL_WEB_PASSWORD=

# Only needed if your user's UID/GID isn't 1000 (check with `id -u`/`id -g`).
# UID=1000
# GID=1000
